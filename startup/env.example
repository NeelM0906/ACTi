# ACTi platform environment file
# Copy to .env and fill in the values. .env is gitignored.

# ---------- REQUIRED: model identity (operator-confidential) ----------
# HuggingFace repo id of the underlying base model.
# Request the correct value from the ACTi platform team.
ACTI_MODEL_ID=

# Tool-call parser name (vLLM nomenclature).
# Must match the chat template format of your base model.
ACTI_TOOL_CALL_PARSER=

# Reasoning parser name (vLLM nomenclature).
# Set to the parser that splits chain-of-thought into reasoning_content.
ACTI_REASONING_PARSER=

# HuggingFace access token (for downloading model weights and faster transfer).
HF_TOKEN=

# ---------- OPTIONAL: inference engine selection ----------
# ACTi defaults to SGLang for MoE base models (e.g. redacted-base-model from
# AMD's day-0 release). Set to "vllm" to use the dense-model fallback engine.
# ACTI_INFERENCE_ENGINE=sglang

# ACTI_SGLANG_VERSION=v0.5.10
# ACTI_SGLANG_PYTHON_ENV=acti-sglang
# ACTI_SGLANG_SRC=/opt/acti-sglang-src

# ---------- OPTIONAL: paths and tunables ----------
# These have sensible defaults — uncomment to override.

# ACTI_ROCM_PATH=/opt/rocm-7.2.1
# ACTI_PYTHON_ENV=acti-inference
# ACTI_HF_HOME=/var/lib/acti/hf-cache
# ACTI_LOG_DIR=/var/log/acti
# ACTI_OWUI_DATA_DIR=/var/lib/acti/openwebui
# ACTI_API_KEY_FILE=/var/lib/acti/api-keys.txt
# ACTI_OWUI_BRANDING_CSS=/opt/acti/ui/owui-branding.css
# ACTI_SYSTEM_PROMPT_PATH=/opt/acti/system_prompts/sohn.txt

# Skill library — directory of <name>/SKILL.md skill packages the proxy loads at
# startup. Sohn sees skill names + descriptions in its prompt and calls a
# `load_skill` tool when it judges one applies. Set to an empty/non-existent path
# to disable the skill system.
# ACTI_SKILLS_DIR=/opt/acti/skills
# ACTI_MAX_SKILL_LOADS=4

# ---------- OPTIONAL: media generation (image / video via Lumen) ----------
# Both must be set together to enable the `generate_image` / `generate_video`
# tools and the OpenAI-compatible /v1/images/generations endpoint. Lumen runs
# on a separate workstation, exposed via ngrok; the proxy holds the bearer
# token server-side and never hands it to the model or the client.
# ACTI_LUMEN_BASE_URL=https://activideo.ngrok.app
# ACTI_LUMEN_AUTH_TOKEN=
# ACTI_MEDIA_DIR=/var/lib/acti/media
# ACTI_LUMEN_IMAGE_TIMEOUT=180
# ACTI_LUMEN_VIDEO_TIMEOUT=600

# ACTI_STATUS_HISTORY_PATH=/usr/share/nginx/html/acti-status/status_history.json
# ACTI_HEALTH_URL=http://127.0.0.1:8080/health

# Inference engine tuning (shared across engines unless noted)
# ACTI_TENSOR_PARALLEL_SIZE=1
# ACTI_INFERENCE_PORT=8000

# SGLang-specific
# ACTI_CONTEXT_LENGTH=262144
# ACTI_MEM_FRACTION_STATIC=0.85
# ACTI_ATTENTION_BACKEND=triton

# vLLM-specific (only consumed by the fallback engine)
# ACTI_MAX_MODEL_LEN=262144
# ACTI_GPU_MEM_UTIL=0.9
# ACTI_VLLM_ATTENTION_BACKEND=TRITON_ATTN

# Throughput: MTP (multi-token-prediction) speculative decoding (vLLM only;
# requires the model checkpoint to ship MTP weights). Set to empty string to
# disable. Ignored by the SGLang engine.
# ACTI_SPECULATIVE_CONFIG={"method":"mtp","num_speculative_tokens":2}

# Sampler defaults merged with the model's generation_config.json (vLLM only).
# Set to empty to disable. Ignored by the SGLang engine.
# ACTI_OVERRIDE_GENERATION_CONFIG={"temperature":0.7,"top_p":0.8,"top_k":20,"repetition_penalty":1.05}

# Proxy / nginx ports
# SOHN_PROXY_PORT=8080
# Public nginx port: edit platform/nginx/nginx.conf if you need a different port.
