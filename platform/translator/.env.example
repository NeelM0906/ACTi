# Sohn LLM (your gateway). Required — no default.
# A plaintext http:// URL is rejected unless you also set SOHN_ALLOW_INSECURE=1.
SOHN_BASE_URL=https://your-sohn-gateway.example.com/v1
SOHN_API_KEY=sk-...
SOHN_MODEL=Sohn
SOHN_MAX_TOKENS=8192
# SOHN_ALLOW_INSECURE=1   # only set on a trusted private network

# OpenAI (for embeddings). Required — no default.
OPENAI_API_KEY=sk-...

# Embeddings (must match index dim — sohn_embedding_sm is 1536-dim)
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone. Required — no default.
PINECONE_API_KEY=pcsk_...
PINECONE_HOST=https://your-index.svc.region.pinecone.io
PINECONE_PRIMARY_NAMESPACE=teachings
PINECONE_SUPPORTING_NAMESPACES=cases,identity
PINECONE_TOP_K_PRIMARY=8
PINECONE_TOP_K_SUPPORTING=2

# Chunking
CHUNK_SIZE=3000
CHUNK_OVERLAP=300

# Concurrency
MAX_CONCURRENT_CHUNKS=4
LLM_MAX_RETRIES=2
LLM_REQUEST_TIMEOUT_S=180
MEMORY_MAX_CHARS=1500
